{
  "name": "presto-mcp-server",
  "version": "1.0.0",
  "description": "MCP server for Presto presupuestos software (BC3/FIEBDC-3 mode)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "presto-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
